GITHUB_TOKEN=ghp_your_github_personal_access_token

# Primary LLM provider -- Gemini by default (see llm_base_url/llm_model in
# config.py to point elsewhere).
LLM_API_KEY=your_gemini_api_key

# Optional fallback provider -- if set, ai_service tries Gemini first and
# only falls back to real OpenAI on failure (bad key, rate limit, outage).
# Leave blank to run with just the primary provider.
OPENAI_API_KEY=

# Shared secret core-api must send as `Authorization: Bearer <this>` -- same
# value goes in career-os's root .env as GITHUB_ANALYZER_SHARED_TOKEN.
GITHUB_ANALYZER_SHARED_TOKEN=dev-only-change-me
